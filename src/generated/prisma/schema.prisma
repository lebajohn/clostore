generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  price       Decimal  @default(0) @db.Decimal(12, 2)
  category    String
  description String
  image       String
  createdAt   DateTime @default(now()) @db.Timestamp(6)
}
