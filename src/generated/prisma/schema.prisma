generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  price       Float
  imageUrl    String
  description String
  createdAt   DateTime @default(now())
}
